import React, { useState, useRef, useEffect, useCallback, memo } from 'react';
import { createPortal } from 'react-dom';
import { Icons } from '../constants';
import { MessageImage, AIModel, AttachedDocument } from '../types';
import * as pdfjsLib from 'pdfjs-dist';
import mammoth from 'mammoth';
import * as XLSX from 'xlsx';
import JSZip from 'jszip';
import SlashCommandMenu from './SlashCommandMenu';

pdfjsLib.GlobalWorkerOptions.workerSrc = `https://cdn.jsdelivr.net/npm/pdfjs-dist@4.4.168/build/pdf.worker.min.mjs`;

interface MessageInputProps {
  onSendMessage: (content: string, image?: MessageImage, docs?: AttachedDocument[]) => void;
  onStop: () => void;
  isDisabled: boolean;
  preferredModel?: AIModel | 'auto';
  onModelChange?: (model: AIModel | 'auto') => void;
  activeSessionId?: string;
}

// ── File type metadata ────────────────────────────────────────────
const FILE_META: Record<string, { label: string; color: string; bg: string; icon: string }> = {
  pdf:  { label: 'PDF',  color: '#f87171', bg: 'rgba(248,113,113,0.10)', icon: '📄' },
  docx: { label: 'DOC',  color: '#60a5fa', bg: 'rgba(96,165,250,0.10)',  icon: '📝' },
  doc:  { label: 'DOC',  color: '#60a5fa', bg: 'rgba(96,165,250,0.10)',  icon: '📝' },
  xlsx: { label: 'XLS',  color: '#34d399', bg: 'rgba(52,211,153,0.10)',  icon: '📊' },
  xls:  { label: 'XLS',  color: '#34d399', bg: 'rgba(52,211,153,0.10)',  icon: '📊' },
  csv:  { label: 'CSV',  color: '#34d399', bg: 'rgba(52,211,153,0.10)',  icon: '📊' },
  json: { label: 'JSON', color: '#fbbf24', bg: 'rgba(251,191,36,0.10)',  icon: '{ }' },
  md:   { label: 'MD',   color: '#a78bfa', bg: 'rgba(167,139,250,0.10)', icon: '📑' },
  zip:  { label: 'ZIP',  color: '#fb923c', bg: 'rgba(251,146,60,0.10)',  icon: '📦' },
  txt:  { label: 'TXT',  color: '#94a3b8', bg: 'rgba(148,163,184,0.10)', icon: '📃' },
  py:   { label: 'PY',   color: '#fbbf24', bg: 'rgba(251,191,36,0.10)',  icon: '🐍' },
  js:   { label: 'JS',   color: '#fbbf24', bg: 'rgba(251,191,36,0.10)',  icon: '⚡' },
  ts:   { label: 'TS',   color: '#60a5fa', bg: 'rgba(96,165,250,0.10)',  icon: '⚡' },
  html: { label: 'HTML', color: '#f97316', bg: 'rgba(249,115,22,0.10)',  icon: '🌐' },
  css:  { label: 'CSS',  color: '#818cf8', bg: 'rgba(129,140,248,0.10)', icon: '🎨' },
};

function getFileMeta(filename: string) {
  const ext = filename.split('.').pop()?.toLowerCase() || 'txt';
  return FILE_META[ext] || { label: ext.toUpperCase().slice(0,4), color: '#94a3b8', bg: 'rgba(148,163,184,0.10)', icon: '📄' };
}

function fmtBytes(bytes: number): string {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}

// ── Waveform bars component ───────────────────────────────────────
const WaveformBars = memo(() => (
  <span className="mi-waveform" aria-hidden="true">
    {[...Array(5)].map((_, i) => (
      <span key={i} className="mi-waveform-bar" style={{ animationDelay: `${i * 80}ms` }} />
    ))}
  </span>
));

// ── Attachment card ───────────────────────────────────────────────
interface AttachCardProps {
  doc: AttachedDocument & { sizeBytes?: number };
  index: number;
  onRemove: (i: number) => void;
}

const AttachCard = memo(({ doc, index, onRemove }: AttachCardProps) => {
  const meta = getFileMeta(doc.title);
  const isZip = doc.title.toLowerCase().endsWith('.zip');
  const fileMatches = isZip ? (doc.content.match(/--- File: /g) || []).length : 0;
  const fileNames = isZip
    ? [...doc.content.matchAll(/--- File: (.+?) ---/g)].slice(0, 3).map(m => m[1].split('/').pop())
    : [];

  return (
    <div className="mi-attach-card" style={{ borderColor: `${meta.color}30` }}>
      {/* Icon */}
      <div className="mi-attach-card-icon" style={{ background: meta.bg, color: meta.color }}>
        <span>{meta.icon}</span>
      </div>

      {/* Info */}
      <div className="mi-attach-card-info">
        <span className="mi-attach-card-name">{doc.title}</span>
        {isZip ? (
          <span className="mi-attach-card-sub" style={{ color: meta.color }}>
            {fileMatches} file{fileMatches !== 1 ? 's' : ''} extracted
          </span>
        ) : (
          <span className="mi-attach-card-sub">
            {meta.label}{doc.sizeBytes ? ` · ${fmtBytes(doc.sizeBytes)}` : ''}
          </span>
        )}
        {isZip && fileNames.length > 0 && (
          <span className="mi-attach-card-files">
            {fileNames.join(', ')}
            {fileMatches > 3 ? ` +${fileMatches - 3} more` : ''}
          </span>
        )}
      </div>

      {/* Remove */}
      <button
        className="mi-attach-card-remove"
        onClick={() => onRemove(index)}
        type="button"
        aria-label={`Remove ${doc.title}`}
      >
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>
  );
});

// ── Image preview card ────────────────────────────────────────────
const ImageCard = memo(({ src, onRemove }: { src: string; onRemove: () => void }) => (
  <div className="mi-img-card">
    <img src={src} alt="Attached" className="mi-img-card-img" />
    <button className="mi-img-card-remove" onClick={onRemove} type="button" aria-label="Remove image">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>
  </div>
));

// ══════════════════════════════════════════════════════════════════
// MAIN COMPONENT
// ══════════════════════════════════════════════════════════════════

const MessageInput: React.FC<MessageInputProps> = ({
  onSendMessage, onStop, isDisabled,
  preferredModel = 'auto', onModelChange, activeSessionId,
}) => {
  const [input, setInput] = useState('');
  const [promptQueue, setPromptQueue] = useState<Array<{ content: string; image?: MessageImage; docs?: AttachedDocument[] }>>([]);
  const [attachedImage, setAttachedImage] = useState<MessageImage | null>(null);
  const [imagePreview, setImagePreview] = useState<string | null>(null);
  const [attachedDocs, setAttachedDocs] = useState<Array<AttachedDocument & { sizeBytes?: number }>>([]);
  const [showModelDropdown, setShowModelDropdown] = useState(false);
  const [hoveredModel, setHoveredModel] = useState<string | null>(null);
  const [isProcessing, setIsProcessing] = useState(false);
  const [showAttachMenu, setShowAttachMenu] = useState(false);
  const [isListening, setIsListening] = useState(false);
  const [isDragOver, setIsDragOver] = useState(false);

  // Slash command state
  const [showSlash, setShowSlash] = useState(false);
  const [slashQuery, setSlashQuery] = useState('');

  const textareaRef = useRef<HTMLTextAreaElement>(null);
  const containerRef = useRef<HTMLDivElement>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);
  const imageInputRef = useRef<HTMLInputElement>(null);
  const cameraInputRef = useRef<HTMLInputElement>(null);
  const dropdownRef = useRef<HTMLDivElement>(null);
  const buttonRef = useRef<HTMLButtonElement>(null);
  const attachMenuRef = useRef<HTMLDivElement>(null);
  const attachBtnRef = useRef<HTMLButtonElement>(null);
  const recognitionRef = useRef<any>(null);
  const isListeningRef = useRef(false);
  const baseInputRef = useRef('');
  const restartCountRef = useRef(0);
  const restartTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);
  const [dropdownPos, setDropdownPos] = useState<{ top: number; left: number } | null>(null);
  const [attachMenuPos, setAttachMenuPos] = useState<{ top: number; left: number } | null>(null);

  const isSpeechSupported = typeof window !== 'undefined' &&
    !!((window as any).SpeechRecognition || (window as any).webkitSpeechRecognition);

  // Focus on session change
  useEffect(() => {
    if (textareaRef.current && window.innerWidth >= 1024) {
      textareaRef.current.focus();
    }
  }, [activeSessionId]);

  // Auto-resize textarea
  useEffect(() => {
    const el = textareaRef.current;
    if (!el) return;
    const raf = requestAnimationFrame(() => {
      el.style.height = 'auto';
      el.style.height = `${Math.min(el.scrollHeight, window.innerHeight * 0.35)}px`;
    });
    return () => cancelAnimationFrame(raf);
  }, [input]);

  // ── Slash command detection ─────────────────────────────────────
  const handleInputChange = useCallback((e: React.ChangeEvent<HTMLTextAreaElement>) => {
    const val = e.target.value;
    setInput(val);

    // Show slash menu when typing "/" at start or after whitespace
    const match = val.match(/(?:^|\n)\/(\w*)$/);
    if (match) {
      setSlashQuery(match[1]);
      setShowSlash(true);
    } else {
      setShowSlash(false);
      setSlashQuery('');
    }
  }, []);

  const handleSlashSelect = useCallback((template: string) => {
    // Replace the /command with the template
    const newInput = input.replace(/(?:^|\n)\/\w*$/, (m) =>
      m.startsWith('\n') ? '\n' + template : template
    );
    setInput(newInput);
    setShowSlash(false);
    setSlashQuery('');
    setTimeout(() => {
      if (textareaRef.current) {
        textareaRef.current.focus();
        const len = newInput.length;
        textareaRef.current.setSelectionRange(len, len);
      }
    }, 10);
  }, [input]);

  // ── Model dropdown ──────────────────────────────────────────────
  const modelColors: Record<string, string> = {
    'auto': 'bg-indigo-500/20 text-indigo-400 border-indigo-500/40',
    [AIModel.GPT4]: 'bg-emerald-500/20 text-emerald-400 border-emerald-500/40',
    [AIModel.CLAUDE]: 'bg-amber-500/20 text-amber-400 border-amber-500/40',
    [AIModel.GEMINI]: 'bg-blue-500/20 text-blue-400 border-blue-500/40',
  };

  const modelExpertise: Record<string, { label: string; expertise: string; detail: string; examples: string }> = {
    'auto': { label: 'Auto', expertise: 'Smart Routing', detail: 'Automatically picks the best engine.', examples: 'Just type — SEDREX routes for you.' },
    [AIModel.GPT4]: { label: 'Reasoning & Planning', expertise: 'Strategic Thinking', detail: 'Best for strategy, trade-offs, frameworks.', examples: 'Compare options, build plans, analyse.' },
    [AIModel.CLAUDE]: { label: 'Coding & Writing', expertise: 'Technical Precision', detail: 'Best for code, debugging, tech docs.', examples: 'Write code, debug errors, draft docs.' },
    [AIModel.GEMINI]: { label: 'Search & Speed', expertise: 'Fast Exploration', detail: 'Real-time lookups, image analysis.', examples: 'Quick facts, live search, summaries.' },
  };

  const updateDropdownPos = useCallback(() => {
    if (buttonRef.current) {
      const r = buttonRef.current.getBoundingClientRect();
      const menuEstH = 200;
      const topAnchor = r.top - 8;
      const clamped = Math.max(menuEstH + 8, topAnchor);
      setDropdownPos({ top: clamped, left: Math.max(8, r.left) });
    }
  }, []);

  const handleToggleDropdown = useCallback(() => {
    if (!showModelDropdown) updateDropdownPos();
    setShowModelDropdown(p => !p);
  }, [showModelDropdown, updateDropdownPos]);

  useEffect(() => {
    if (!showModelDropdown) return;
    const handler = (e: MouseEvent) => {
      if (dropdownRef.current?.contains(e.target as Node) || buttonRef.current?.contains(e.target as Node)) return;
      setShowModelDropdown(false);
    };
    document.addEventListener('mousedown', handler);
    return () => document.removeEventListener('mousedown', handler);
  }, [showModelDropdown]);

  // ── Attach menu ─────────────────────────────────────────────────
  const updateAttachPos = useCallback(() => {
    if (attachBtnRef.current) {
      const r = attachBtnRef.current.getBoundingClientRect();
      // Anchor to the TOP of the button; menu opens upward via translateY(-100%)
      // Clamp so menu never disappears above viewport
      const menuEstH = 220; // estimated menu height px
      const topAnchor = r.top - 8;
      const clamped = Math.max(menuEstH + 8, topAnchor);
      setAttachMenuPos({ top: clamped, left: Math.max(8, r.left) });
    }
  }, []);

  const handleToggleAttachMenu = useCallback(() => {
    if (!showAttachMenu) updateAttachPos();
    setShowAttachMenu(p => !p);
  }, [showAttachMenu, updateAttachPos]);

  useEffect(() => {
    if (!showAttachMenu) return;
    const handler = (e: MouseEvent) => {
      if (attachMenuRef.current?.contains(e.target as Node) || attachBtnRef.current?.contains(e.target as Node)) return;
      setShowAttachMenu(false);
    };
    document.addEventListener('mousedown', handler);
    return () => document.removeEventListener('mousedown', handler);
  }, [showAttachMenu]);

  // ── Voice / Speech recognition ──────────────────────────────────
  const MAX_RESTARTS = 15;

  const startRecognition = useCallback(() => {
    const SR = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    if (!SR) { isListeningRef.current = false; setIsListening(false); return; }
    if (recognitionRef.current) {
      try { recognitionRef.current.onend = null; recognitionRef.current.abort(); } catch {}
      recognitionRef.current = null;
    }
    const r = new SR();
    r.continuous = false; r.interimResults = true; r.lang = 'en-US'; r.maxAlternatives = 1;
    r.onresult = (e: any) => {
      restartCountRef.current = 0;
      let interim = '', finalText = '';
      for (let i = e.resultIndex; i < e.results.length; i++) {
        const t = e.results[i][0].transcript;
        if (e.results[i].isFinal) finalText += t + ' ';
        else interim = t;
      }
      if (finalText) {
        const base = baseInputRef.current;
        baseInputRef.current = (base + (base && !base.endsWith(' ') ? ' ' : '') + finalText).trimEnd() + ' ';
        setInput(baseInputRef.current);
      } else {
        setInput(baseInputRef.current + interim);
      }
    };
    r.onerror = (e: any) => {
      if (e.error === 'no-speech' || e.error === 'aborted') return;
      isListeningRef.current = false; setIsListening(false);
    };
    r.onend = () => {
      if (isListeningRef.current && restartCountRef.current < MAX_RESTARTS) {
        restartCountRef.current++;
        restartTimerRef.current = setTimeout(() => {
          if (isListeningRef.current) startRecognition();
        }, /Mobi|Android|iPhone/i.test(navigator.userAgent) ? 400 : 300);
      } else {
        isListeningRef.current = false; setIsListening(false);
      }
    };
    try { r.start(); recognitionRef.current = r; }
    catch { isListeningRef.current = false; setIsListening(false); }
  }, []);

  const stopRecognition = useCallback(() => {
    isListeningRef.current = false; setIsListening(false);
    if (restartTimerRef.current) { clearTimeout(restartTimerRef.current); restartTimerRef.current = null; }
    if (recognitionRef.current) {
      try { recognitionRef.current.onend = null; recognitionRef.current.abort(); } catch {}
      recognitionRef.current = null;
    }
    setInput(p => p.trim());
    baseInputRef.current = '';
  }, []);

  const toggleVoice = useCallback(() => {
    if (isListeningRef.current) { stopRecognition(); return; }
    baseInputRef.current = input; restartCountRef.current = 0;
    const begin = () => { isListeningRef.current = true; setIsListening(true); startRecognition(); };
    if (!/Mobi|Android|iPhone|iPad/i.test(navigator.userAgent) && navigator.mediaDevices?.getUserMedia) {
      navigator.mediaDevices.getUserMedia({ audio: true })
        .then(s => { s.getTracks().forEach(t => t.stop()); begin(); })
        .catch(() => begin());
    } else {
      begin();
    }
  }, [input, startRecognition, stopRecognition]);

  useEffect(() => () => {
    if (restartTimerRef.current) clearTimeout(restartTimerRef.current);
    if (recognitionRef.current) { try { recognitionRef.current.abort(); } catch {} }
  }, []);

  // ── File processing ─────────────────────────────────────────────
  const processFile = useCallback(async (file: File) => {
    setIsProcessing(true);
    try {
      if (file.type.startsWith('image/')) {
        const reader = new FileReader();
        reader.onload = () => {
          const b64 = reader.result as string;
          setImagePreview(b64);
          setAttachedImage({ inlineData: { data: b64.split(',')[1] }, mimeType: file.type });
        };
        reader.readAsDataURL(file);
        return;
      }
      const ext = file.name.split('.').pop()?.toLowerCase();
      let content = '';
      if (ext === 'pdf') {
        const ab = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({ data: ab }).promise;
        for (let i = 1; i <= pdf.numPages; i++) {
          const page = await pdf.getPage(i);
          const tc = await page.getTextContent();
          content += tc.items.map((x: any) => x.str).join(' ') + '\n';
        }
      } else if (ext === 'docx') {
        const ab = await file.arrayBuffer();
        content = (await mammoth.extractRawText({ arrayBuffer: ab })).value;
      } else if (['xlsx', 'xls', 'csv'].includes(ext || '')) {
        const ab = await file.arrayBuffer();
        const wb = XLSX.read(ab);
        content = XLSX.utils.sheet_to_csv(wb.Sheets[wb.SheetNames[0]]);
      } else if (ext === 'zip') {
        const ab = await file.arrayBuffer();
        const zip = await JSZip.loadAsync(ab);
        const textExts = new Set(['txt','md','json','csv','xml','html','css','js','ts','tsx','jsx','py','java','c','cpp','h','rb','go','rs','sh','yml','yaml','toml','ini','sql','prisma','svelte','vue','php','swift','kt']);
        let out = `ZIP Archive: ${file.name}\n`;
        let count = 0;
        for (const [name, zf] of Object.entries(zip.files) as [string, any][]) {
          if (zf.dir || count >= 30) continue;
          const fext = name.split('.').pop()?.toLowerCase() || '';
          if (!textExts.has(fext)) { out += `\n--- File: ${name} --- [binary, skipped]\n`; count++; continue; }
          try {
            const text = await zf.async('text');
            out += `\n--- File: ${name} ---\n${text.slice(0, 10000)}\n`;
            if (text.length > 10000) out += `... (truncated)\n`;
          } catch { out += `\n--- File: ${name} --- [unreadable]\n`; }
          count++;
        }
        content = out;
      } else {
        content = await file.text();
      }
      setAttachedDocs(prev => [...prev, { title: file.name, content, type: file.type || ext || 'text/plain', sizeBytes: file.size }]);
    } catch (err) { console.error('File processing failed:', err); }
    finally { setIsProcessing(false); }
  }, []);

  const handleFileChange = useCallback((e: React.ChangeEvent<HTMLInputElement>) => {
    if (e.target.files) Array.from(e.target.files).forEach(processFile);
    if (fileInputRef.current) fileInputRef.current.value = '';
    if (imageInputRef.current) imageInputRef.current.value = '';
    setShowAttachMenu(false);
  }, [processFile]);

  // ── Drag and drop ───────────────────────────────────────────────
  const handleDragOver = useCallback((e: React.DragEvent) => {
    e.preventDefault(); setIsDragOver(true);
  }, []);
  const handleDragLeave = useCallback(() => setIsDragOver(false), []);
  const handleDrop = useCallback((e: React.DragEvent) => {
    e.preventDefault(); setIsDragOver(false);
    Array.from(e.dataTransfer.files).forEach(processFile);
  }, [processFile]);

  // ── Paste handling (images + files) ────────────────────────────
  useEffect(() => {
    const handler = (e: ClipboardEvent) => {
      const items = e.clipboardData?.items;
      if (!items) return;
      for (const item of Array.from(items)) {
        if (item.kind === 'file') {
          const file = item.getAsFile();
          if (file) { e.preventDefault(); processFile(file); }
        }
      }
    };
    document.addEventListener('paste', handler);
    return () => document.removeEventListener('paste', handler);
  }, [processFile]);

  // ── Submit ──────────────────────────────────────────────────────
  const handleSubmit = useCallback(() => {
    const trimmed = input.trim();
    if ((!trimmed && !attachedImage && attachedDocs.length === 0) || isProcessing) return;
    if (!isDisabled) {
      onSendMessage(trimmed, attachedImage || undefined, attachedDocs);
    } else {
      setPromptQueue(p => [...p, { content: trimmed, image: attachedImage || undefined, docs: attachedDocs }]);
    }
    setInput(''); setAttachedImage(null); setImagePreview(null); setAttachedDocs([]);
    if (textareaRef.current) { textareaRef.current.style.height = 'auto'; textareaRef.current.focus(); }
  }, [input, attachedImage, attachedDocs, isDisabled, isProcessing, onSendMessage]);

  // Process prompt queue
  useEffect(() => {
    if (!isDisabled && promptQueue.length > 0 && !isProcessing) {
      const next = promptQueue[0];
      setPromptQueue(p => p.slice(1));
      onSendMessage(next.content, next.image, next.docs);
    }
  // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [isDisabled, promptQueue, isProcessing]);

  const handleKeyDown = useCallback((e: React.KeyboardEvent<HTMLTextAreaElement>) => {
    if (showSlash && (e.key === 'ArrowUp' || e.key === 'ArrowDown' || e.key === 'Tab')) {
      e.preventDefault(); return;
    }
    if (e.key === 'Enter' && !e.shiftKey && window.innerWidth >= 768) {
      e.preventDefault(); handleSubmit();
    }
  }, [showSlash, handleSubmit]);

  const hasContent = input.trim() || attachedImage || attachedDocs.length > 0;
  const hasAttachments = imagePreview || attachedDocs.length > 0;

  return (
    <div
      className={`mi-root${isDragOver ? ' mi-root--drag' : ''}`}
      onDragOver={handleDragOver}
      onDragLeave={handleDragLeave}
      onDrop={handleDrop}
    >
      {/* Model selector row */}
      <div className="mi-model-row">
        <button
          ref={buttonRef}
          onClick={handleToggleDropdown}
          disabled={isDisabled}
          className={`mi-model-btn ${modelColors[preferredModel] || modelColors['auto']}`}
          type="button"
        >
          <Icons.Robot className="mi-model-icon" />
          <span>{modelExpertise[preferredModel]?.label ?? 'Auto'}</span>
          <svg className={`mi-model-chevron${showModelDropdown ? ' mi-model-chevron--open' : ''}`} width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5">
            <path d="M6 9l6 6 6-6" />
          </svg>
        </button>

        {isProcessing && (
          <div className="mi-processing">
            <div className="mi-processing-dot" />
            <span>Processing file…</span>
          </div>
        )}

        {/* Slash hint */}
        <span className="mi-slash-hint">Type <kbd>/</kbd> for commands</span>
      </div>

      {/* Model dropdown portal */}
      {showModelDropdown && dropdownPos && createPortal(
        <div
          ref={dropdownRef}
          className="mi-dropdown"
          style={{ position: 'fixed', top: dropdownPos.top, left: dropdownPos.left, transform: 'translateY(-100%)', zIndex: 9999 }}
        >
          <div className="mi-dropdown-list">
            {(['auto', AIModel.GPT4, AIModel.CLAUDE, AIModel.GEMINI] as const).map((m) => {
              const icons: Record<string, string> = { auto: '✨', [AIModel.GPT4]: '🧠', [AIModel.CLAUDE]: '⚡', [AIModel.GEMINI]: '🔍' };
              return (
                <button
                  key={m}
                  onMouseEnter={() => setHoveredModel(m)}
                  onClick={() => { onModelChange?.(m); setShowModelDropdown(false); }}
                  className={`mi-dropdown-item${preferredModel === m ? ' mi-dropdown-item--active' : ''}`}
                  type="button"
                >
                  <span className="mi-dropdown-item-icon">{icons[m]}</span>
                  <span>{modelExpertise[m]?.label}</span>
                </button>
              );
            })}
          </div>
          <div className="mi-dropdown-detail">
            {hoveredModel ? (
              <>
                <p className="mi-dropdown-detail-title">{modelExpertise[hoveredModel]?.expertise}</p>
                <p className="mi-dropdown-detail-body">{modelExpertise[hoveredModel]?.detail}</p>
                <p className="mi-dropdown-detail-ex">{modelExpertise[hoveredModel]?.examples}</p>
              </>
            ) : (
              <div className="mi-dropdown-detail-empty">
                <Icons.Shield className="mi-dropdown-shield" />
              </div>
            )}
          </div>
        </div>,
        document.body
      )}

      {/* Main input box */}
      <div
        ref={containerRef}
        className={`mi-box${isDragOver ? ' mi-box--drag' : ''}`}
      >
        {/* Drag overlay */}
        {isDragOver && (
          <div className="mi-drag-overlay">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12" />
            </svg>
            <span>Drop files to attach</span>
          </div>
        )}

        {/* Attachment cards */}
        {hasAttachments && (
          <div className="mi-attach-row">
            {imagePreview && (
              <ImageCard
                src={imagePreview}
                onRemove={() => { setAttachedImage(null); setImagePreview(null); }}
              />
            )}
            {attachedDocs.map((doc, i) => (
              <AttachCard
                key={`${doc.title}-${i}`}
                doc={doc}
                index={i}
                onRemove={(idx) => setAttachedDocs(p => p.filter((_, j) => j !== idx))}
              />
            ))}
          </div>
        )}

        {/* Input row */}
        <div className="mi-input-row">
          {/* Attach button */}
          <button
            ref={attachBtnRef}
            onClick={handleToggleAttachMenu}
            disabled={isDisabled || isProcessing}
            className={`mi-icon-btn${showAttachMenu ? ' mi-icon-btn--active' : ''}`}
            type="button"
            aria-label="Attach files"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={`mi-attach-icon${showAttachMenu ? ' mi-attach-icon--open' : ''}`}>
              <path d="M12 5v14M5 12h14" />
            </svg>
          </button>

          {/* Textarea */}
          <textarea
            ref={textareaRef}
            value={input}
            onChange={handleInputChange}
            onKeyDown={handleKeyDown}
            placeholder="Message SEDREX… (or type / for commands)"
            className="mi-textarea"
            rows={1}
            aria-label="Chat message input"
          />

          {/* Right buttons */}
          <div className="mi-right-btns">
            {isSpeechSupported && (!input.trim() || isListening) && !isDisabled && (
              <button
                onClick={toggleVoice}
                className={`mi-icon-btn mi-mic-btn${isListening ? ' mi-mic-btn--active' : ''}`}
                type="button"
                aria-label={isListening ? 'Stop listening' : 'Voice input'}
              >
                {isListening ? <WaveformBars /> : <Icons.Mic className="mi-icon-sm" />}
              </button>
            )}
            <button
              onClick={isDisabled ? onStop : handleSubmit}
              disabled={!isDisabled && !hasContent}
              className={`mi-send-btn${isDisabled ? ' mi-send-btn--stop' : hasContent ? ' mi-send-btn--active' : ' mi-send-btn--disabled'}`}
              type="button"
              aria-label={isDisabled ? 'Stop generating' : 'Send message'}
            >
              {isDisabled ? (
                <svg viewBox="0 0 24 24" fill="currentColor" className="mi-icon-sm">
                  <rect x="6" y="6" width="12" height="12" rx="1.5" />
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" className="mi-icon-sm">
                  <path d="M12 19V5M5 12l7-7 7 7" />
                </svg>
              )}
            </button>
          </div>
        </div>
      </div>

      {/* Attach menu portal */}
      {showAttachMenu && attachMenuPos && createPortal(
        <div
          ref={attachMenuRef}
          className="mi-attach-menu"
          style={{ position: 'fixed', top: attachMenuPos.top, left: attachMenuPos.left, transform: 'translateY(-100%)', zIndex: 9999 }}
        >
          <button onClick={() => { imageInputRef.current?.click(); setShowAttachMenu(false); }} className="mi-attach-menu-item" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" className="mi-attach-menu-icon">
              <rect width="18" height="18" x="3" y="3" rx="2" /><circle cx="9" cy="9" r="2" />
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
            </svg>
            <span>Upload image</span>
          </button>
          <button onClick={() => { cameraInputRef.current?.click(); setShowAttachMenu(false); }} className="mi-attach-menu-item mi-attach-menu-item--mobile" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" className="mi-attach-menu-icon">
              <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3Z" />
              <circle cx="12" cy="13" r="3" />
            </svg>
            <span>Camera</span>
          </button>
          <button onClick={() => { fileInputRef.current?.click(); setShowAttachMenu(false); }} className="mi-attach-menu-item" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.8" className="mi-attach-menu-icon">
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
              <polyline points="14 2 14 8 20 8" />
            </svg>
            <span>Upload file</span>
          </button>
          <div className="mi-attach-menu-hint">PDF, DOCX, XLSX, JSON, ZIP, code…</div>
        </div>,
        document.body
      )}

      {/* Hidden file inputs */}
      <input ref={fileInputRef} type="file" className="hidden" accept=".txt,.md,.json,.csv,.pdf,.docx,.xlsx,.xls,.zip,.py,.js,.ts,.tsx,.jsx,.html,.css,.sql,.sh,.yaml,.yml" onChange={handleFileChange} multiple aria-label="Attach file" />
      <input ref={imageInputRef} type="file" className="hidden" accept="image/*" onChange={handleFileChange} aria-label="Attach image" />
      <input ref={cameraInputRef} type="file" className="hidden" accept="image/*" capture="environment" onChange={handleFileChange} aria-label="Take photo" />

      {/* Slash command menu */}
      {showSlash && (
        <SlashCommandMenu
          anchorEl={containerRef.current}
          query={slashQuery}
          onSelect={handleSlashSelect}
          onClose={() => setShowSlash(false)}
        />
      )}
    </div>
  );
};

export default MessageInput;
