/* ================================================================
   SEDREX — MessageInput.css
   Claude-style input bar with attachment cards, waveform, slash menu
   ================================================================ */

/* ── Root wrapper ────────────────────────────────────────── */
.mi-root {
  padding: 12px 16px 16px;
  background: var(--bg-primary);
  flex-shrink: 0;
  flex-grow: 0;
  align-self: stretch;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  z-index: 35;
  padding-bottom: max(16px, env(safe-area-inset-bottom, 16px));
  transition: background 200ms ease;
  position: relative;
  border-top: 1px solid var(--border);
}
.mi-root--drag { background: rgba(201,168,76,0.04); }

/* ── Model selector row ──────────────────────────────────── */
.mi-model-row {
  width: 100%;
  max-width: 768px;
  margin: 0 auto 10px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.mi-model-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  font-size: 12px;
  font-weight: 600;
  border-radius: 999px;
  border: 1px solid;
  cursor: pointer;
  transition: filter 150ms ease, transform 120ms ease;
  letter-spacing: 0.01em;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.mi-model-btn:hover:not(:disabled)  { filter: brightness(1.12); }
.mi-model-btn:active:not(:disabled) { transform: scale(0.95); }
.mi-model-btn:disabled              { opacity: 0.45; cursor: not-allowed; }
.mi-model-icon { width: 13px; height: 13px; flex-shrink: 0; }
.mi-model-chevron { transition: transform 200ms ease; }
.mi-model-chevron--open { transform: rotate(180deg); }

.mi-processing {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: #34d399;
  animation: pulse 1.5s ease-in-out infinite;
}
.mi-processing-dot { width: 6px; height: 6px; border-radius: 50%; background: #34d399; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }

.mi-slash-hint {
  margin-left: auto;
  font-size: 11px;
  color: var(--text-secondary);
  opacity: 0.38;
  font-family: 'IBM Plex Mono', monospace;
  letter-spacing: 0.02em;
  white-space: nowrap;
}
.mi-slash-hint kbd {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 16px;
  height: 16px;
  padding: 0 3px;
  font-family: inherit;
  font-size: 11px;
  border-radius: 3px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  color: var(--accent, #c9a84c);
  font-weight: 700;
}
@media (max-width: 480px) { .mi-slash-hint { display: none; } }

/* ── Main input box ──────────────────────────────────────── */
.mi-box {
  width: 100%;
  max-width: 768px;
  margin: 0 auto;
  background: var(--bg-secondary, #0d1117);
  border: 1px solid var(--border);
  border-radius: 20px;
  transition: border-color 180ms ease, box-shadow 180ms ease;
  box-shadow: 0 2px 16px rgba(0,0,0,0.15);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}
.mi-box:focus-within {
  border-color: rgba(201,168,76,0.35);
  box-shadow: 0 4px 20px rgba(0,0,0,0.18);
}
.mi-box--drag {
  border-color: rgba(201,168,76,0.5) !important;
  box-shadow: 0 0 0 3px rgba(201,168,76,0.12) !important;
}
[data-theme='light'] .mi-box {
  background: #faf9f6;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
[data-theme='light'] .mi-box:focus-within {
  border-color: rgba(138,104,32,0.4);
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
}

/* ── Drag overlay ────────────────────────────────────────── */
.mi-drag-overlay {
  position: absolute;
  inset: 0;
  background: rgba(201,168,76,0.07);
  border-radius: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 600;
  color: var(--accent, #c9a84c);
  z-index: 10;
  pointer-events: none;
}

/* ── Attachment cards row ────────────────────────────────── */
.mi-attach-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 12px 12px 0;
  max-height: 200px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
.mi-attach-row::-webkit-scrollbar { height: 3px; width: 3px; }
.mi-attach-row::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* ── Attachment card ─────────────────────────────────────── */
.mi-attach-card {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  padding: 8px 10px;
  border-radius: 10px;
  border: 1px solid;
  background: var(--bg-primary);
  position: relative;
  min-width: 140px;
  max-width: 220px;
  animation: card-pop 200ms cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes card-pop {
  from { opacity: 0; transform: scale(0.88); }
  to   { opacity: 1; transform: scale(1); }
}
.mi-attach-card-icon {
  width: 30px; height: 30px;
  border-radius: 7px;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
}
.mi-attach-card-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
.mi-attach-card-name {
  font-size: 12px; font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  display: block;
}
.mi-attach-card-sub {
  font-size: 11px; color: var(--text-secondary); opacity: 0.65;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.mi-attach-card-files {
  font-size: 10px; color: var(--text-secondary); opacity: 0.5;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.mi-attach-card-remove {
  position: absolute; top: -6px; right: -6px;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--bg-primary);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--text-secondary);
  opacity: 0;
  transition: opacity 140ms ease, background 140ms ease;
  -webkit-tap-highlight-color: transparent;
}
.mi-attach-card:hover .mi-attach-card-remove,
.mi-attach-card-remove:focus { opacity: 1; }
.mi-attach-card-remove:hover { background: #ef4444; color: #fff; border-color: #ef4444; }
@media (hover: none) { .mi-attach-card-remove { opacity: 0.7; } }

/* ── Image card ──────────────────────────────────────────── */
.mi-img-card {
  position: relative; width: 64px; height: 64px;
  border-radius: 10px; overflow: visible; flex-shrink: 0;
  animation: card-pop 200ms cubic-bezier(0.34,1.56,0.64,1) both;
}
.mi-img-card-img {
  width: 64px; height: 64px; border-radius: 10px;
  object-fit: cover; border: 1px solid var(--border); display: block;
}
.mi-img-card-remove {
  position: absolute; top: -6px; right: -6px;
  width: 18px; height: 18px; border-radius: 50%;
  background: var(--bg-primary); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--text-secondary); opacity: 0;
  transition: opacity 140ms ease, background 140ms ease;
}
.mi-img-card:hover .mi-img-card-remove { opacity: 1; }
.mi-img-card-remove:hover { background: #ef4444; color: #fff; border-color: #ef4444; }
@media (hover: none) { .mi-img-card-remove { opacity: 0.7; } }

/* ── Input row ───────────────────────────────────────────── */
.mi-input-row {
  display: flex;
  align-items: flex-end;
  gap: 4px;
  padding: 8px 8px 8px 10px;
}

/* ── Icon buttons ────────────────────────────────────────── */
.mi-icon-btn {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 10px; border: none;
  background: transparent; color: var(--text-secondary);
  cursor: pointer; flex-shrink: 0;
  transition: color 140ms ease, background 140ms ease;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
  align-self: flex-end; margin-bottom: 2px;
}
.mi-icon-btn:hover     { color: var(--text-primary); background: rgba(201,168,76,0.06); }
.mi-icon-btn--active   { color: var(--text-primary); background: rgba(201,168,76,0.06); }
.mi-icon-btn:disabled  { opacity: 0.3; cursor: not-allowed; }
.mi-attach-icon { width: 18px; height: 18px; transition: transform 200ms ease; }
.mi-attach-icon--open { transform: rotate(45deg); }
.mi-icon-sm { width: 16px; height: 16px; }

/* ── Textarea ────────────────────────────────────────────── */
.mi-textarea {
  flex: 1;
  background: transparent; border: none; outline: none;
  -webkit-appearance: none; box-shadow: none; resize: none;
  font-family: 'IBM Plex Sans', ui-sans-serif, system-ui, sans-serif;
  font-size: 15px; line-height: 1.65; color: var(--text-primary);
  padding: 8px 4px; max-height: 35vh;
  overflow-y: auto; scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
.mi-textarea::placeholder { color: var(--text-secondary); opacity: 0.38; }
.mi-textarea::-webkit-scrollbar { width: 3px; }
.mi-textarea::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* ── Right buttons ───────────────────────────────────────── */
.mi-right-btns {
  display: flex; align-items: center; gap: 2px;
  flex-shrink: 0; align-self: flex-end; padding-bottom: 2px;
}

/* ── Mic / waveform ──────────────────────────────────────── */
.mi-mic-btn { position: relative; }
.mi-mic-btn--active { color: #ef4444 !important; background: rgba(239,68,68,0.08) !important; }
.mi-waveform { display: flex; align-items: center; gap: 2px; height: 18px; }
.mi-waveform-bar {
  display: block; width: 3px; border-radius: 2px; background: #ef4444;
  animation: waveform-bounce 0.9s ease-in-out infinite;
}
.mi-waveform-bar:nth-child(1) { height: 8px; }
.mi-waveform-bar:nth-child(2) { height: 14px; }
.mi-waveform-bar:nth-child(3) { height: 18px; }
.mi-waveform-bar:nth-child(4) { height: 14px; }
.mi-waveform-bar:nth-child(5) { height: 8px; }
@keyframes waveform-bounce {
  0%, 100% { transform: scaleY(0.5); opacity: 0.7; }
  50%       { transform: scaleY(1);   opacity: 1;   }
}

/* ── Send button ─────────────────────────────────────────── */
.mi-send-btn {
  width: 36px; height: 36px; border-radius: 10px; border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; flex-shrink: 0;
  transition: background 150ms ease, transform 120ms ease, opacity 150ms ease;
  -webkit-tap-highlight-color: transparent; touch-action: manipulation;
}
.mi-send-btn--active  { background: var(--text-primary); color: var(--bg-primary); }
.mi-send-btn--active:hover  { filter: brightness(1.08); }
.mi-send-btn--active:active { transform: scale(0.93); }
.mi-send-btn--stop { background: #ef4444; color: #fff; box-shadow: 0 2px 12px rgba(239,68,68,0.25); }
.mi-send-btn--stop:hover  { background: #dc2626; }
.mi-send-btn--stop:active { transform: scale(0.93); }
.mi-send-btn--disabled { background: transparent; color: var(--text-secondary); opacity: 0.2; cursor: not-allowed; }

/* ── Attach menu ─────────────────────────────────────────── */
.mi-attach-menu {
  width: 220px;
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: 14px; overflow: hidden;
  box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  padding: 6px;
  animation: menu-in 150ms cubic-bezier(0.22,1,0.36,1) both;
}
@keyframes menu-in {
  from { opacity: 0; transform: scale(0.95) translateY(4px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
.mi-attach-menu-item {
  display: flex; align-items: center; gap: 10px;
  width: 100%; padding: 10px; border: none;
  background: transparent; border-radius: 8px; cursor: pointer;
  font-size: 14px; font-weight: 500; color: var(--text-primary);
  text-align: left; transition: background 120ms ease;
  -webkit-tap-highlight-color: transparent;
}
.mi-attach-menu-item:hover { background: rgba(201,168,76,0.06); }
.mi-attach-menu-item--mobile { display: none; }
@media (max-width: 768px) { .mi-attach-menu-item--mobile { display: flex; } }
.mi-attach-menu-icon { width: 18px; height: 18px; color: var(--text-secondary); flex-shrink: 0; }
.mi-attach-menu-hint {
  padding: 6px 10px 4px; font-size: 10px;
  color: var(--text-secondary); opacity: 0.4;
  font-family: 'IBM Plex Mono', monospace;
  border-top: 1px solid var(--border); margin-top: 2px;
}

/* ── Model dropdown ──────────────────────────────────────── */
.mi-dropdown {
  display: flex;
  width: min(20rem, calc(100vw - 32px));
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: 16px; overflow: hidden;
  box-shadow: 0 8px 40px rgba(0,0,0,0.3);
  animation: menu-in 150ms cubic-bezier(0.22,1,0.36,1) both;
}
.mi-dropdown-list { width: 180px; border-right: 1px solid var(--border); padding: 6px 0; flex-shrink: 0; }
.mi-dropdown-item {
  display: flex; align-items: center; gap: 8px;
  width: 100%; padding: 10px 14px; border: none;
  background: transparent; font-size: 13px; font-weight: 600;
  color: var(--text-primary); cursor: pointer; text-align: left;
  transition: background 120ms ease, color 120ms ease;
}
.mi-dropdown-item:hover   { background: rgba(201,168,76,0.06); }
.mi-dropdown-item--active { background: rgba(201,168,76,0.08); color: var(--accent, #c9a84c); }
.mi-dropdown-item-icon    { font-size: 14px; flex-shrink: 0; }
.mi-dropdown-detail {
  flex: 1; padding: 16px; background: rgba(201,168,76,0.02);
  display: flex; flex-direction: column; justify-content: center; min-height: 140px;
}
.mi-dropdown-detail-title { font-size: 12px; font-weight: 700; color: var(--accent, #c9a84c); margin: 0 0 6px; letter-spacing: 0.02em; }
.mi-dropdown-detail-body  { font-size: 12px; color: var(--text-secondary); margin: 0 0 8px; line-height: 1.55; opacity: 0.8; }
.mi-dropdown-detail-ex    { font-size: 11px; color: var(--text-secondary); opacity: 0.5; font-style: italic; margin: 0; }
.mi-dropdown-detail-empty { display: flex; align-items: center; justify-content: center; opacity: 0.15; }
.mi-dropdown-shield { width: 28px; height: 28px; }

/* ── Reduced motion ──────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .mi-waveform-bar, .mi-processing, .mi-attach-card, .mi-img-card { animation: none !important; }
  .mi-box, .mi-send-btn, .mi-icon-btn { transition: none !important; }
}