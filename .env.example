# ══════════════════════════════════════════════════════════════════
# SEDREX AI — .env.example
# This file is SAFE to commit to git — no real keys here.
# Copy this to .env.local and fill in your actual values.
# ══════════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Gemini API Keys ────────────────────────────────────────────────
API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_KEY_1=your_gemini_key_1_here
GEMINI_KEY_2=your_gemini_key_2_here
# GEMINI_KEY_3=your_gemini_key_3_here
# GEMINI_KEY_4=your_gemini_key_4_here
# GEMINI_KEY_5=your_gemini_key_5_here
# GEMINI_KEY_6=your_gemini_key_6_here

# ── Google Search (optional - for live grounding) ─────────────────
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_custom_search_engine_id_here

# ── Site URL ───────────────────────────────────────────────────────
VITE_SITE_URL=http://localhost:3000

# ── Optional AI Keys ──────────────────────────────────────────────
# VITE_OPENAI_API_KEY=sk-...
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# ── Optional Stripe ───────────────────────────────────────────────
# VITE_STRIPE_PUBLIC_KEY=pk_...

# ── App ────────────────────────────────────────────────────────────
VITE_ENV=development
VITE_DEBUG=false

# ── SEDREX Engine ─────────────────────────────────────────────────
NEXUS_RATE_MAX_PER_WINDOW=60
NEXUS_RATE_WINDOW_MS=60000
NEXUS_MAX_CONCURRENT_REQUESTS=8
NEXUS_MAX_QUEUED_REQUESTS=1000
NEXUS_API_KEY_COOLDOWN_MS=30000
NEXUS_CIRCUIT_FAIL_THRESHOLD=10
NEXUS_CIRCUIT_FAIL_WINDOW_MS=30000
NEXUS_CIRCUIT_OPEN_MS=15000
NEXUS_RESPONSE_CACHE_TTL_MS=0
